[Unit]
Description=Proxmox VE Monthly Hoover Timer
Documentation=man:systemd.timer(5)
Requires=pve-monthly-hoover.service

[Timer]
# Run on the 1st of every month at 02:00 AM
OnCalendar=*-*-01 02:00:00
Persistent=true
Accuracy=1h

# If system was down at scheduled time, run it on next boot
OnBootSec=10min

# Randomize start by up to 15 minutes to avoid thundering herd on clusters
RandomizedDelaySec=15min

[Install]
WantedBy=timers.target
