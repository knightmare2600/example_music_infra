###############################################################################
# Example Music Infrastructure - Git Line Ending Policy
###############################################################################

# Default behaviour
* text=auto

###############################################################################
# Linux / Unix files (always LF)
###############################################################################

*.sh          text eol=lf
*.bash        text eol=lf
*.zsh         text eol=lf
*.py          text eol=lf
*.pl          text eol=lf

*.yml         text eol=lf
*.yaml        text eol=lf

*.cfg         text eol=lf
*.conf        text eol=lf
*.cnf         text eol=lf
*.ini         text eol=lf

*.ipxe        text eol=lf

*.service     text eol=lf
*.socket      text eol=lf
*.timer       text eol=lf
*.mount       text eol=lf
*.target      text eol=lf
*.path        text eol=lf
*.slice       text eol=lf
*.scope       text eol=lf
*.network     text eol=lf
*.netdev      text eol=lf
*.link        text eol=lf

*.rules       text eol=lf
*.env         text eol=lf

*.md          text eol=lf
*.txt         text eol=lf

###############################################################################
# Windows files (always CRLF)
###############################################################################

*.ps1         text eol=crlf
*.psm1        text eol=crlf
*.psd1        text eol=crlf

*.bat         text eol=crlf
*.cmd         text eol=crlf

*.reg         text eol=crlf

###############################################################################
# Binary files (never modify line endings)
###############################################################################

*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.bmp         binary
*.ico         binary
*.svg         binary

*.pdf         binary
*.zip         binary
*.7z          binary
*.gz          binary
*.xz          binary
*.bz2         binary
*.tar         binary
*.tgz         binary
*.iso         binary

*.exe         binary
*.dll         binary
*.msi         binary

*.woff        binary
*.woff2       binary
*.ttf         binary
*.otf         binary