; ============================================================
; /etc/bind/db.192.168.139
; Example Music Limited -- provisioning network reverse zone
;
; Zone:    139.168.192.in-addr.arpa
; Covers:  192.168.139.0/24  (provisioning network)
; Server:  EXASVRCLD001 ({{ dns_ip }})
; Managed by: Ansible bind9-dns.yml
; Generated:  {{ ansible_date_time.iso8601 }}
;
; PTR records:
;   .10  EXASVRCLD001   -- this DNS server
;   .50  EXAPRVCLD001   -- provisioning / PXE server
;   .49  EXASVRCLD003  -- Ansible control node
;   .X   exafwl{site}001-wan  -- firewall WAN face per site
;        where X = the site's /24 third octet (from sites.csv)
;
; The -wan suffix distinguishes each firewall's provisioning-network
; address from its LAN address (exafwl{site}001 in its own subnet).
;
; This zone is NOT generated by the per-site loop. CLD's own subnet
; is 192.168.139.0/24 -- handling it here avoids a duplicate zone.
; ============================================================

$ORIGIN 139.168.192.in-addr.arpa.
$TTL {{ zone_ttl }}

@   IN  SOA  exasvrcld001.{{ domain }}.  hostmaster.{{ domain }}. (
              {{ zone_serial }}  ; serial
              3600       ; refresh
              900        ; retry
              604800     ; expire
              {{ zone_ttl }}        ; minimum
            )

@   IN  NS   exasvrcld001.{{ domain }}.

; ── Ancillary / management hosts ─────────────────────────────
; EXASVR numbering: 001=DNS(.10) 002=WAC(.20) 003=Ansible(.49) 004=Rudder(.22)
10    IN  PTR  exasvrcld001.{{ domain }}.     ; DNS/BIND server (this host)
20    IN  PTR  exasvrcld002.{{ domain }}.     ; Windows Admin Centre
22    IN  PTR  exasvrcld004.{{ domain }}.     ; Rudder configuration management
48    IN  PTR  exacldpbx001.{{ domain }}.     ; Central 3CX PBX
49    IN  PTR  exasvrcld003.{{ domain }}.     ; Ansible control node
50    IN  PTR  exaprvcld001.{{ domain }}.     ; Provisioning / PXE

; ── Firewall WAN PTR records ──────────────────────────────────
; 192.168.139.{octet}  ->  exafwl{site}001-wan.{{ domain }}.
; Sorted by octet ascending.
{% for site in sites | sort(attribute='octet') %}
{{ "%-5s" | format(site.octet) }} IN  PTR  {{ "%-50s" | format('exafwl' + site.Site | lower + '001-wan.' + domain + '.') }} ; {{ site.Site }} ({{ site.City }})
{% endfor %}
