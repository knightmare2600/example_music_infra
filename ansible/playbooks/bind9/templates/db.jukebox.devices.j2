; ============================================================
; /etc/bind/db.{{ domain }}
; Example Music Limited -- {{ domain }} forward zone
;
; Authoritative DNS: EXADNSCLD001 ({{ dns_ip }})
; Zone:              {{ domain }}
; Source:            devices.csv (single source of truth)
; Managed by:        Ansible bind9-dns.yml Play 2
; Generated:         {{ ansible_date_time.iso8601 }}
;
; A records are generated for every device with a HostOctet in devices.csv.
; Devices without a HostOctet (non-networked assets: vehicles, aircraft etc.)
; are emitted as comments so they remain documented without DNS resolution.
;
; CLD BLACK SWAN:
;   CLD (192.168.139.0/24) is the provisioning network. It does not follow
;   standard site convention. Its devices have manually assigned IPs.
;   CLD devices are listed first and separately from the per-site blocks.
;
; SOA serial format: YYYYMMDDnn
; TTL: {{ zone_ttl }}s -- short TTL for fast provisioning propagation.
;
; DO NOT EDIT this file by hand except to add one-off records at the bottom.
; Regenerate with: ansible-playbook bind9-dns.yml --tags zones-full,reload
; ============================================================

$ORIGIN {{ domain }}.
$TTL {{ zone_ttl }}

; ── SOA + NS ─────────────────────────────────────────────────
@   IN  SOA  exadnscld001.{{ domain }}.  hostmaster.{{ domain }}. (
              {{ zone_serial }}  ; serial   YYYYMMDDnn
              3600       ; refresh  1 hour
              900        ; retry    15 minutes
              604800     ; expire   1 week
              {{ zone_ttl }}        ; minimum  {{ zone_ttl }}s
            )

@   IN  NS   exadnscld001.{{ domain }}.

; ── FWL WAN addresses on provisioning network (192.168.139.{octet}) ──────────
; Each site firewall has a WAN interface on 192.168.139.0/24.
; Host octet = site subnet third octet. -wan suffix distinguishes from LAN face.
{% for site in sites_raw.list
   | rejectattr('Site', 'equalto', 'BRD')
   | rejectattr('Site', 'equalto', 'Site')
   | rejectattr('Subnet', 'equalto', 'N/A')
   | sort(attribute='Site') %}
{% set octet = site.Subnet.split('.')[2] %}
{{ "%-45s" | format('exafwl' + site.Site | lower + '001-wan') }} IN  A  192.168.139.{{ octet }}   ; {{ site.Site }} WAN face on provisioning net
{% endfor %}

; ── CLD -- Cloud / Provisioning (192.168.139.0/24) ───────────
; BLACK SWAN: provisioning network -- not a standard site.
; IPs are manually assigned for specific provisioning roles.
{% set cld_devices = all_devices | selectattr('Site', 'equalto', 'CLD') | list %}
{% for dev in cld_devices | sort(attribute='HostOctet') %}
{% if dev.HostOctet != '' %}
{{ "%-45s" | format(dev.Hostname | lower) }} IN  A  {{ dev.full_ip }}{{ '   ; ' + dev.Notes if dev.Notes else '' }}
{% else %}
; NO-IP  {{ dev.Hostname | lower }}  -- {{ dev.Notes | default('non-networked asset') }}
{% endif %}
{% endfor %}

; ── Per-site device records ───────────────────────────────────
; Grouped by site, sorted by HostOctet within each site.
; Devices without a HostOctet are documented as comments.
{% set non_cld = all_devices | rejectattr('Site', 'equalto', 'CLD') | list %}
{% set site_codes = non_cld | map(attribute='Site') | unique | sort | list %}
{% for site_code in site_codes %}
{% set site_devs = non_cld | selectattr('Site', 'equalto', site_code) | list %}
{% set subnet = sites_by_code.get(site_code, '') %}
{% set octet = subnet.split('.')[2] if subnet else '?' %}

; ── {{ site_code }}  (192.168.{{ octet }}.0/24) ───────────────
{% for dev in site_devs | sort(attribute='HostOctet') %}
{% if dev.HostOctet != '' %}
{{ "%-45s" | format(dev.Hostname | lower) }} IN  A  {{ dev.full_ip }}{{ '   ; ' + dev.Notes if dev.Notes else '' }}
{% else %}
; NO-IP  {{ dev.Hostname | lower }}{{ '  -- ' + dev.Notes if dev.Notes else '' }}
{% endif %}
{% endfor %}
{% endfor %}

; ── DHCP pool ($GENERATE) ─────────────────────────────────────
; .100–.199 per site — forward records only.
; PTR $GENERATE blocks are in each per-site reverse zone file.
; CLD (provisioning network) has no DHCP pool.
{% for site in sites_raw.list
   | rejectattr('Site', 'equalto', 'BRD')
   | rejectattr('Site', 'equalto', 'Site')
   | rejectattr('Site', 'equalto', 'CLD')
   | rejectattr('Subnet', 'equalto', 'N/A')
   | sort(attribute='Site') %}
{% set octet = site.Subnet.split('.')[2] %}
; {{ site.Site }} -- 192.168.{{ octet }}.100-199
$GENERATE 100-199 dhcp${-99,2,d}.{{ site.Site | lower }} IN A 192.168.{{ octet }}.$
{% endfor %}

; ── One-off records -- add below, DO NOT edit above ──────────
; Records added here are preserved between Ansible runs only if
; you manage them outside the template. Increment SOA serial manually.
