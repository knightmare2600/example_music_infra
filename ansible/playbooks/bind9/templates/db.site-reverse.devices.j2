; ============================================================
; /etc/bind/db.192.168.{{ sites_by_code[item].split('.')[2] }}
; Example Music Limited -- reverse zone
;
; Zone:    {{ sites_by_code[item].split('.')[2] }}.168.192.in-addr.arpa
; Covers:  {{ sites_by_code[item] | regex_replace('/24', '.0/24') }}  ({{ item }})
; Source:  devices.csv (single source of truth)
; Server:  EXASVRCLD001 ({{ dns_ip }})
; Managed: Ansible bind9-dns.yml Play 2
; Generated: {{ ansible_date_time.iso8601 }}
;
; PTR records generated for all devices in devices.csv with a HostOctet.
; Non-networked assets (blank HostOctet) are documented as comments.
; ============================================================

{% set site_octet = sites_by_code[item].split('.')[2] %}
$ORIGIN {{ site_octet }}.168.192.in-addr.arpa.
$TTL {{ zone_ttl }}

@   IN  SOA  exasvrcld001.{{ domain }}.  hostmaster.{{ domain }}. (
              {{ zone_serial }}  ; serial
              3600       ; refresh
              900        ; retry
              604800     ; expire
              {{ zone_ttl }}        ; minimum
            )

@   IN  NS   exasvrcld001.{{ domain }}.

; ── PTR records (192.168.{{ site_octet }}.x) ─────────────────
{% set site_devs = all_devices
   | selectattr('Site', 'equalto', item)
   | sort(attribute='HostOctet') | list %}
{% for dev in site_devs %}
{% if dev.HostOctet != '' %}
{{ "%-5s" | format(dev.HostOctet) }} IN  PTR  {{ dev.Hostname | lower }}.{{ domain }}.{{ '   ; ' + dev.Notes if dev.Notes else '' }}
{% else %}
; NO-IP  {{ dev.Hostname | lower }}{{ '  -- ' + dev.Notes if dev.Notes else '' }}
{% endif %}
{% endfor %}
