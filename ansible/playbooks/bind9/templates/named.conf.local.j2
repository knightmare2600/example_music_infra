// ============================================================
// named.conf.local -- Example Music Limited
// EXASVRCLD001  --  {{ domain }}
// Managed by Ansible bind9-dns.yml -- do not edit by hand
// Generated: {{ ansible_date_time.iso8601 }}
//
// Forward zone:   {{ domain }}
// Reverse zones:
//   139.168.192.in-addr.arpa  -- dedicated provisioning zone
//                                (FWL WAN IPs + ancillary hosts)
//   X.168.192.in-addr.arpa    -- one per site /24 (CLD excluded)
// ============================================================

// ── Forward zone: {{ domain }} ───────────────────────────
zone "{{ domain }}" {
  type master;
  file "{{ bind_zone_dir }}/db.{{ domain }}";
  allow-query   { any; };
  allow-transfer { none; };
  notify no;
};

// ── Reverse zone: provisioning network 192.168.139.0/24 ──────
// Dedicated zone -- FWL WAN IPs for all sites + ancillary hosts.
// NOT generated by the per-site loop (avoids collision with CLD subnet).
zone "139.168.192.in-addr.arpa" {
  type master;
  file "{{ bind_zone_dir }}/db.192.168.139";
  allow-query   { any; };
  allow-transfer { none; };
  notify no;
};

{% for site in sites | rejectattr('Site', 'equalto', 'CLD') | sort(attribute='octet') %}
// ── Reverse zone: 192.168.{{ site.octet }}.0/24  ({{ site.Site }} -- {{ site.City }}) ──
zone "{{ site.octet }}.168.192.in-addr.arpa" {
  type master;
  file "{{ bind_zone_dir }}/db.192.168.{{ site.octet }}";
  allow-query   { any; };
  allow-transfer { none; };
  notify no;
};

{% endfor %}
