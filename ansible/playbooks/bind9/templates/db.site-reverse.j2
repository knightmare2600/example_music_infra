; ============================================================
; /etc/bind/db.192.168.{{ item.octet }}
; Example Music Limited -- reverse zone
;
; Zone:    {{ item.octet }}.168.192.in-addr.arpa
; Covers:  192.168.{{ item.octet }}.0/24  ({{ item.Site }} -- {{ item.City }})
; Server:  EXADNSCLD001 ({{ dns_ip }})
; Managed by: Ansible bind9-dns.yml
; Generated:  {{ ansible_date_time.iso8601 }}
;
; PTR records cover the standard static SUFFIX_MAP addresses.
; DHCP pool .100-.199 PTR records are covered via $GENERATE at the end of this file.
; ============================================================

$ORIGIN {{ item.octet }}.168.192.in-addr.arpa.
$TTL {{ zone_ttl }}

@   IN  SOA  exadnscld001.{{ domain }}.  hostmaster.{{ domain }}. (
              {{ zone_serial }}  ; serial
              3600       ; refresh
              900        ; retry
              604800     ; expire
              {{ zone_ttl }}        ; minimum
            )

@   IN  NS   exadnscld001.{{ domain }}.

; ── PTR records (192.168.{{ item.octet }}.x) ─────────────────────────
{% for entry in suffix_map %}
{% if entry.suffix == 12 %}
{% set hostname = 'exarry' + item.Site | lower + '%03d' | format(entry.seq) + '.' + domain + '.' %}
{% else %}
{% set hostname = entry.prefix + item.Site | lower + '%03d' | format(entry.seq) + '.' + domain + '.' %}
{% endif %}
{{ "%-5s" | format(entry.suffix) }} IN  PTR  {{ hostname }}
{% endfor %}

; ── DHCP pool PTR ($GENERATE) ─────────────────────────────────
; .100–.199  →  dhcp01.{{ item.Site | lower }}.{{ domain }}. through dhcp100.{{ item.Site | lower }}.{{ domain }}.
$GENERATE 100-199 $ IN PTR dhcp${-99,2,d}.{{ item.Site | lower }}.{{ domain }}.
