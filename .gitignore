# =============================================================================
# .gitignore — Example Music Infrastructure Repo
# =============================================================================

# ── SSH private keys ──────────────────────────────────────────────────────────
# The ansible SSH keypair lives in ansible/configs/ on the control node.
# The public key is safe to commit; the private key must NEVER be committed.
ansible/configs/ansible-id_rsa
ansible/configs/ansible-id_rsa.pub

# ── Ansible generated files ───────────────────────────────────────────────────
# ansible/configs/inventory/main.ini is generated by ansibleme.sh at runtime.
# The manually curated per-site/per-service .ini files (cld.ini, kge.ini, etc.)
# ARE tracked — only the generated discovery output is excluded.
ansible/configs/inventory/main.ini

# ansible/files/devices.csv is populated by ansibleme.sh from the canonical
# source at /etc/example-music/devices.csv (or downloaded from the provisioning
# server). The authoritative copy is bootstrap/web/proxmox/devices.csv.
ansible/files/devices.csv

# Retry files written by ansible-playbook on failure
*.retry

# Vault password files — never commit these
.vault_pass
.vault_pass.txt
vault_pass
vault_pass.txt
*_vault_pass
*_vault_pass.txt

# ── Python ────────────────────────────────────────────────────────────────────
*.pyc
*.pyo
__pycache__/
*.egg-info/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.AppleDouble
.LSOverride

# ── Editor artifacts ──────────────────────────────────────────────────────────
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# ── Claude Code session memory ────────────────────────────────────────────────
# Local memory files for resuming Claude Code sessions. Not for public consumption.
.claude/

# ── Temporary / local ─────────────────────────────────────────────────────────
*.log
*.tmp
*.bak
*.orig
