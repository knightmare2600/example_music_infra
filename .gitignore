###############################################################################
# Example Music Infrastructure
# .gitignore
#
# Philosophy:
#   - Source code, documentation, templates and rare vendor packages are kept.
#   - Generated files, caches, logs and local downloads are ignored.
###############################################################################

###############################################################################
# Operating Systems
###############################################################################

Thumbs.db
Desktop.ini
ehthumbs.db
.DS_Store
.claude

###############################################################################
# Editors
###############################################################################

.vscode/
.idea/
*.swp
*.swo
*~

###############################################################################
# Python
###############################################################################

__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

###############################################################################
# Ansible
###############################################################################

*.retry
ansible.log

###############################################################################
# Logs
###############################################################################

*.log
access_log
error_log
agent_log
referer_log

###############################################################################
# Temporary / backup files
###############################################################################

*.tmp
*.temp
*.bak
*.old
*.orig

###############################################################################
# Local notes / scratch files
###############################################################################

scratchpad*
*.local.txt

###############################################################################
# Generated Linux boot files
#
# These are recreated from upstream mirrors.
###############################################################################

**/vmlinuz*
**/bzImage*
**/initrd*
**/initramfs*

###############################################################################
# Preserve boot scripts
###############################################################################

!**/*.ipxe
!**/*.seed

###############################################################################
# Generated WinPE output
###############################################################################

bootstrap/web/windows/x86_64/Boot/
bootstrap/web/windows/arm64/Boot/

###############################################################################
# Generated ISO extraction directories
###############################################################################

mount/
mnt/
extract/
extracted/

###############################################################################
# Virtual Machines
###############################################################################

*.vhd
*.vhdx
*.vmdk
*.qcow2
*.qcow2.xz

###############################################################################
# ISO working directory
#
# Safe to ignore because ISOs can be recreated or downloaded.
###############################################################################

ISOs/

###############################################################################
# Build output
###############################################################################

dist/
build/
out/

###############################################################################
# Terraform
###############################################################################

.terraform/
terraform.tfstate*
*.tfvars

###############################################################################
# Secrets
###############################################################################

.env
.env.*
*.key
*.pem
*.pfx
*.p12

###############################################################################
# SSH Keys
###############################################################################

id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub
id_ecdsa
id_ecdsa.pub
authorized_keys

###############################################################################
# Windows crash dumps
###############################################################################

*.dmp

###############################################################################
# Keep archives by default.
#
# Many firmware packages, legacy installers and vendor downloads are intentionally
# committed because they are difficult or impossible to obtain today.
#
# Ignore individual download/cache directories instead of every ZIP/EXE.
###############################################################################
